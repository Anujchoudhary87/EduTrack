generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  clicks    ButtonClick[]
  watches   VideoWatchTime[]
  scrolls   ScrollDepth[]
  quizzes   QuizResult[]
  createdAt DateTime @default(now())
}

model QuizResult {
  id            String   @id @default(uuid())
  userId        String?  // Relation to User
  user          User?    @relation(fields: [userId], references: [id])
  contentId     String
  score         Int
  totalQuestions Int
  recordedAt    DateTime @default(now())

  @@index([contentId])
}

model ButtonClick {
  id            String   @id @default(uuid())
  userId        String?  // Relation to User
  user          User?    @relation(fields: [userId], references: [id])
  buttonLabel   String
  contentId     String
  clickedAt     DateTime @default(now())

  @@index([contentId, buttonLabel])
}

model VideoWatchTime {
  id              String   @id @default(uuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  videoId         String
  contentId       String
  watchedSeconds  Int
  recordedAt      DateTime @default(now())

  @@index([videoId])
}

model ScrollDepth {
  id                  String   @id @default(uuid())
  userId              String?
  user                User?    @relation(fields: [userId], references: [id])
  contentId           String
  maxScrollPercentage Int      // 0 to 100
  recordedAt          DateTime @default(now())

  @@index([contentId])
}
